{
  "expo": {
    "name": "MovieTracker",
    "slug": "movietracker-mobile",
    "scheme": "movietracker",
    "version": "1.0.12",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "androidStatusBar": {
      "hidden": true,
      "backgroundColor": "#050706",
      "translucent": true
    },
    "androidNavigationBar": {
      "backgroundColor": "#050706",
      "barStyle": "light-content"
    },
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "MovieTracker uses your photos to update your profile picture and banner."
        }
      ],
      "expo-image",
      [
        "expo-notifications",
        {
          "icon": "./assets/android-notification-icon.png",
          "color": "#ff563d",
          "defaultChannel": "episode-releases"
        }
      ],
      [
        "expo-secure-store",
        {
          "configureAndroidBackup": true
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.johnthebakker.movietracker",
      "versionCode": 13,
      "blockedPermissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.SYSTEM_ALERT_WINDOW"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#060808",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
